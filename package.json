    "startwatch": "pm2 start app.js --name GestaoHoras --watch",
    "stop": "pm2 stop GestaoHoras",
    "stopwatch": "pm2 stop GestaoHoras",
    "restart": "pm2 restart GestaoHoras",
    "reload": "pm2 reload GestaoHoras",
    "delete": "pm2 delete GestaoHoras",
    "logs": "pm2 logs GestaoHoras",
    "list": "pm2 list",
    "monit": "pm2 monit",
    "save": "pm2 save",
    "dev": "nodemon app.js",
    "build": "npm --prefix client run build",
    "client": "npm --prefix client run dev",
    "preview": "npm --prefix client run preview",
    "install:all": "npm install && npm --prefix client install",
    "startTest": "pm2 start app.js -i 2 --name GestaoHoras && npm --prefix client run preview"
  },
