{
  "name": "gestao-horas-client",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "start": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --report-unused-disable-directives --fix"
  },
  "//deps": [
    "@emotion/react + @emotion/styled are NOT imported directly: they are required peer",
