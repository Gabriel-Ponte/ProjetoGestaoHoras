    "@mui/x-date-pickers/AdapterDateFns. Removing them breaks the date/time pickers."
  ],
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.11",
    "@mui/x-date-pickers": "^8.29.2",
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.18.1",
    "date-fns": "^4.4.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9",
    "react-icons": "^5.7.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1",
    "react-toastify": "^11.1.0",
    "react-widgets": "^5.8.6",
    "styled-components": "^6.4.3"
  },
  "//overrides": [
    "The `esbuild` and `@octokit/rest` overrides were removed: neither package is in",
    "the tree any more. Vite 8 transforms/minifies with Oxc instead of esbuild, and",
    "vite-plugin-mkcert@2 no longer pulls in Octokit."
  ],
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.14.7",
    "@eslint/js": "^9.39.5",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fs-extra": "^11.3.6",
    "globals": "^17.7.0",
    "node-openssl-cert": "^0.1.44",
    "vite": "^8.1.4",
    "vite-plugin-mkcert": "^2.1.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "//": [
    "Change punycode   /client/node_modules/fast-url-parser/src/urlparser.js",
    "Url.prototype._hostIdna = function Url$_hostIdna(hostname) {",
    "return new URL(`http://${hostname}`).hostname;",
    "};",
    "OR Change punycode add a /",
    "var punycode = require('punycode/');"
  ]
}
